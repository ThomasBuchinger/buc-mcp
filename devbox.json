{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.1/.schema/devbox.schema.json",
  "packages": [
    "python314@latest",
    "uv@latest",
    "opencode@latest"
  ],
  "env": {
    "GITHUB_REPOSITORY": "thomasbuchinger/buc-mcp",
    "CONTEXT7_API_KEY": "ctx7sk-fe28535d-c192-49ef-acda-f4682ad8b461"
  },
  "shell": {
    "scripts": {
      "test": [
        "uv sync --frozen && uv run pytest"
      ],
      "version": [
        "uv run semantic-release version --print 2>/dev/null || echo 'no release needed'"
      ],
      "release": [
        "uv run semantic-release version"
      ],
      "build": [
        "VERSION=$(uv run semantic-release version --print 2>/dev/null || true)",
        "if [ -z \"$VERSION\" ]; then echo 'No release needed — skipping build'; exit 0; fi",
        "echo \"Building container image version: $VERSION\"",
        "docker build -t ghcr.io/$GITHUB_REPOSITORY:$VERSION .",
        "echo \"Tagged: ghcr.io/$GITHUB_REPOSITORY:$VERSION\""
      ],
      "publish": [
        "uv run semantic-release version || { echo 'No release needed — skipping publish'; exit 0; }",
        "VERSION=$(grep '^version' pyproject.toml | head -1 | sed 's/.*\"\\(.*\\)\"/\\1/')",
        "docker build -t ghcr.io/$GITHUB_REPOSITORY:v$VERSION .",
        "docker push ghcr.io/$GITHUB_REPOSITORY:v$VERSION",
        "echo \"Published: ghcr.io/$GITHUB_REPOSITORY:v$VERSION\""
      ]
    }
  }
}
